{
  "name": "2",
  "version": "1.0.0",
  "description": "Task 2: Playwright framework",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:report": "npx playwright show-report",
    "test:debug": "npx playwright test --debug",
    "test:generate": "npx playwright codegen",
    "test:allure": "npx playwright test --reporter=line,allure-playwright",
    "after:tests": "npx allure generate allure-results --clean -o allure-report && cp -r allure-report allure-history"
  },
