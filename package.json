{
    "devDependencies": {
        "@badeball/cypress-cucumber-preprocessor": "^23.2.1",
        "@bahmutov/cypress-esbuild-preprocessor": "^2.2.6",
        "@faker-js/faker": "^10.1.0",
        "cypress": "^15.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "cypress-cucumber-preprocessor": {
        "stepDefinitions": "cypress/e2e/step_definitions/*.ts"
    },
    "scripts": {
        "test": "npx cypress run --config-file config/cypress.config.ts",
        "test:edge": "npx cypress run --config-file config/cypress.config.edge.ts",
        "test:all": "npm run test && npx run test:edge",
        "open": "npx cypress open --config-file config/cypress.config.ts",
        "open:edge": "npx cypress open --config-file config/cypress.config.edge.ts"
    }
}