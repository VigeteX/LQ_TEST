{
  "name": "7",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.20.0",
    "@wdio/cli": "^9.20.0",
    "@wdio/devtools-service": "^8.46.0",
    "@wdio/local-runner": "^9.20.0",
    "@wdio/mocha-framework": "^9.20.0",
    "@wdio/spec-reporter": "^9.20.0",
    "allure-commandline": "^2.34.1",
    "npm-run-all": "^4.1.5"
  },
  "scripts": {
    "wdio": "wdio run ./config/wdio.conf.ts",
    "test:all": "run-s test:chrome test:firefox",
    "test:chrome": "wdio run ./config/wdio.conf.ts",
    "test:firefox": "wdio run ./config/wdio.firefox.conf.ts",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:docker": "docker run --rm -v '${PWD}/allure-results:/app/allure-results' wdio-tests"
  }
}
